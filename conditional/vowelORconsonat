//WAP to check if consonant or vowel
#include<stdio.h>
int main(){

    char ch;
    printf("Enter a charater: \n");
    scanf("%c",&ch);

    if (ch>=65 && ch<=90)
    {
       if (ch=='A'||ch=='E'||ch=='I'||ch=='O'||ch=='U')
       {
        printf("Character is vowel");
       }
        else{
        printf("Charater is consonat");
        }
    }
       else{
        printf("Charater is invalid");
       }
    
}
